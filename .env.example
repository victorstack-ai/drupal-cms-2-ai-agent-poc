# Drupal site base URL (required)
DRUPAL_BASE_URL=http://localhost

# OAuth / Bearer token for authenticated requests (optional)
DRUPAL_TOKEN=

# OpenAI API key for AI-powered planning (optional -- omit to use rule-based planner)
OPENAI_API_KEY=

# OpenAI model to use (optional, defaults to o3-mini)
OPENAI_MODEL=o3-mini
